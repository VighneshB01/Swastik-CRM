# Production Environment Variables for Vercel
# Copy this to your Vercel project settings as environment variables

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SB_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_IS_DEMO=false

# Optional: Inbound Email (if using Postmark)
# VITE_INBOUND_EMAIL=your_postmark_inbound_email
